# Security Warning: Keep your SECRET_KEY secret in production!
SECRET_KEY=django-insecure-your-super-secret-key-change-me

# Set to False in production
DEBUG=True

# Allow your domain or IP here (e.g., example.com,127.0.0.1,localhost)
ALLOWED_HOSTS=127.0.0.1,localhost

# Database connection URL
# Use this format for PostgreSQL: postgres://USER:PASSWORD@HOST:PORT/NAME
# The below URL matches the docker-compose credentials
DATABASE_URL=postgres://survey_user:survey_password@db:5432/survey_db

# Example of SQLite connection if needed locally without Docker
# DATABASE_URL=sqlite:///db.sqlite3
